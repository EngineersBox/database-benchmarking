<configuration>
    <property>
        <name>hbase.rootdir</name>
        <value>hdfs://@@HDFS_NAME_NODE@@:9000/hbase</value>
    </property>
    <property>
        <name>hbase.region.server.rpc.scheduler.factory.class</name>
        <value>org.apache.hadoop.hbase.regionserver.SimpleRpcSchedulerFactory</value>
    </property>
    <property>
        <name>hbase.master.rpc.scheduler.factory.class</name>
        <value>org.apache.hadoop.hbase.regionserver.MasterFifoRpcSchedulerFactory</value>
    </property>
    <property>
        <name>hbase.ipc.server.callqueue.type</name>
        <value>fifo</value>
    </property>
    <property>
    <!-- Default: 0 -->
        <name>hbase.ipc.server.callqueue.read.ratio</name>
        <value>0</value>
    </property>
    <property>
    <!-- Default: 0 -->
        <name>hbase.ipc.server.callqueue.scan.ratio</name>
        <value>0</value>
    </property>
    <property>
    <!-- Default: 0.1 -->
        <name>hbase.ipc.server.callqueue.handler.factor</name>
        <value>0.1</value>
    </property>
    <property>
    <!-- Default: 100 -->
        <name>hbase.regionserver.handler.count</name>
        <value>128</value>
    </property>
    <property>
    <!-- Default: 0.4 -->
        <name>hfile.block.cache.size</name>
        <value>0.4</value>
    </property>
    <property>
        <name>hbase.master.wait.on.regionservers.mintostart</name>
        <value>2</value>
    </property>
    <property>
        <name>hbase.master.wait.on.regionservers.maxtostart</name>
        <value>2</value>
    </property>
    <property>
    <!-- Default: false -->
        <name>hbase.storescanner.parallel.seek.enable</name>
        <value>true</value>
    </property>
    <property>
    <!-- Default: true -->
        <name>hbase.ipc.client.tcpnodelay</name>
        <value>true</value>
    </property>
    <property>
    <!-- Default: 0.4 -->
        <name>hbase.regionserver.global.memstore.size</name>
        <value>0.4</value>
    </property>
    <property>
    <!-- Default: 0.95 -->
        <name>hbase.regionserver.global.memstore.size.lower.limit</name>
        <value>0.95</value>
    </property>
    <property>
        <name>hbase.hregion.memstore.flush.size</name>
        <value></value>
    </property>
    <!-- <property> -->
    <!-- By default this is 95% of hbase.regionserver.global.memstore.size -->
    <!--     <name>hbase.regionserver.global.memstore.size.lower.limit</name> -->
    <!--     <value></value> -->
    <!-- </property> -->
    <!-- <property> -->
    <!-- By default this is Integer.MAX_VALUE  -->
    <!--     <name>hbase.htable.thread.max</name> -->
    <!--     <value>16</value> -->
    <!-- </property> -->
    <property>
        <name>hbase.zookeeper.property.maxClientCnxns</name>
        <value>3000</value>
    </property>
    <property>
        <name>hbase.cluster.distributed</name>
        <value>true</value>
    </property>
    <property>
    <!-- Default: 100 -->
        <name>hbase.client.max.total.tasks</name>
        <value>128</value>
    </property>
    <property>
        <name>hbase.client.max.perserver.tasks</name>
        <value>@@CLIENT_MAX_PER_SERVER_TASKS@@</value>
    </property>
    <property>
        <name>hbase.client.max.perregion.tasks</name>
        <value>@@CLIENT_MAX_PER_REGION_TASKS@@</value>
    </property>
    <property>
        <name>hbase.zookeeper.quorum</name>
        <value>@@ZOOKEEPER_NODE_IPS@@</value>
    </property>
    <property>
        <name>hbase.zookeeper.property.dataDir</name>
        <value>/etc/zookeeper</value>
    </property>
    <property>
        <name>hbase.master.hostname</name>
        <value>@@MASTER_HOSTNAME@@</value>
    </property>
    <property>
        <name>hbase.unsafe.regionserver.hostname</name>
        <value>@@REGIONSERVER_HOSTNAME@@</value>
    </property>
</configuration>
